    { title: "Material Archaeology / 素材の考古学", category: "Framework", image: "assets/images/about-01.jpg", descriptionEN: "A research attitude that reads traces, time, culture, and memory embedded within materials before transforming them into new structures.", descriptionJP: "素材に刻まれた痕跡、時間、文化、記憶を読み解き、新たな構造へ変換するための研究態度。", references: ["TBD"], related: ["Technofossil Archive", "COCOON ANATOMY"] },
    { title: "Sericulture / 養蚕", category: "Textile Culture", image: "assets/images/cocoon-01.jpg", descriptionEN: "A cultural and material field for understanding silk, cocoons, human labor, and the relationship between organism, land, and textile production.", descriptionJP: "絹、繭、人の手仕事、生物・土地・布づくりの関係性を読み解く文化的・素材的な研究領域。", references: ["TBD"], related: ["COCOON ANATOMY"] },
    { title: "Cocoon Structure / 繭の構造", category: "Material Study", image: "assets/images/cocoon-02.jpg", descriptionEN: "An inquiry into the layered structure of cocoon material and the way it protects, wraps, and records life processes.", descriptionJP: "繭の層構造と、それが保護し、包み、生命のプロセスを記録する仕組みへの考察。", references: ["TBD"], related: ["COCOON ANATOMY", "PHANTOM IN THE COCOON"] },
    { title: "Kibiso / キビソ", category: "Material Study", image: "assets/images/cocoon-06.jpg", descriptionEN: "A cocoon-derived material connected to sericulture and silk waste, studied as a carrier of memory and a source for material transformation.", descriptionJP: "養蚕と絹の副産物に関わる素材。記憶を宿す素材であり、素材変換の起点として扱う。", references: ["TBD"], related: ["COCOON ANATOMY"] },
    { title: "Sericin / セリシン", category: "Material Study", image: "assets/images/cocoon-07.jpg", descriptionEN: "TBD. This entry is prepared for later research notes and verified references on sericin.", descriptionJP: "TBD。セリシンに関する研究メモや確認済み文献を追加するための項目です。", references: ["TBD"], related: ["COCOON ANATOMY"] },
    { title: "Fibroin / フィブロイン", category: "Material Study", image: "assets/images/cocoon-08.jpg", descriptionEN: "TBD. This entry is prepared for later research notes and verified references on fibroin.", descriptionJP: "TBD。フィブロインに関する研究メモや確認済み文献を追加するための項目です。", references: ["TBD"], related: ["COCOON ANATOMY"] },
    { title: "Silkworm Behavior / 蚕の行動", category: "Behavior / Culture", image: "assets/images/phantom-03.jpg", descriptionEN: "A research theme for reading the act of spinning, wrapping, and transforming as a cultural and material metaphor.", descriptionJP: "糸を吐き、包み、変化する行為を、文化的・素材的メタファーとして読み解く研究テーマ。", references: ["TBD"], related: ["PHANTOM IN THE COCOON"] },
    { title: "Material Transformation / 素材変換", category: "Process", image: "assets/images/cocoon-11.jpg", descriptionEN: "Processes that move material from waste, residue, or fragment toward new textile, object, archive, or spatial form.", descriptionJP: "廃材、残渣、断片を、テキスタイル、オブジェクト、アーカイブ、空間へと移行させるプロセス。", references: ["TBD"], related: ["COCOON ANATOMY", "Technofossil Archive"] },
    { title: "Why We Research Sericulture", category: "Essay", image: "assets/images/cocoon-12.jpg", descriptionEN: "Sericulture stores histories of land, labor, organism, industry, and modernization. Researching it allows the studio to reconnect material production with memory and ecology.", descriptionJP: "養蚕には土地、労働、生物、産業、近代化の歴史が蓄積されています。これを研究することは、素材生産を記憶と生態の関係へ結び直す行為です。", references: ["TBD"], related: ["COCOON ANATOMY"] },
    { title: "Technofossil Archive Research", category: "Future Archaeology", image: "assets/images/technofossil-02.jpg", descriptionEN: "A research archive for reading contemporary waste and artificial materials as fossils of the future through traces, composition, environmental burden, and preserved time.", descriptionJP: "現代の廃棄物や人工物を、痕跡、素材構成、環境負荷、保存される時間を通じて未来の化石として読み解く研究アーカイブ。", references: ["TBD"], related: ["Technofossil Archive"] },
    { title: "Anthropocene", category: "Keyword", image: "assets/images/technofossil-08.jpg", descriptionEN: "A conceptual background for understanding how human-made materials have begun to shape geological and cultural records.", descriptionJP: "人工物が地質学的・文化的記録を形づくりはじめた状況を考えるための概念的背景。", references: ["TBD"], related: ["Technofossil Archive"] },
    { title: "Technofossil", category: "Keyword", image: "assets/images/technofossil-09.jpg", descriptionEN: "A future fossil: a human-made object or material that may remain as a trace of contemporary civilization.", descriptionJP: "未来の地層に残る可能性のある人工物や人工素材を、現代文明の痕跡として捉えるためのキーワード。", references: ["TBD"], related: ["Technofossil Archive"] },
    { title: "Ossuary", category: "Reference", image: "assets/images/technofossil-10.jpg", descriptionEN: "A reference point for thinking about naming, decorating, preserving, and archiving remains as communal memory.", descriptionJP: "遺骨を名付け、装飾し、保存し、共同体の記憶として扱う構造を考えるための参照点。", references: ["TBD"], related: ["Technofossil Archive"] },
    { title: "Preservation", category: "Process", image: "assets/images/technofossil-11.jpg", descriptionEN: "A process of protecting, recording, and extending the time of an object without erasing its trace.", descriptionJP: "物体の痕跡を消すことなく、保護し、記録し、時間を延長するプロセス。", references: ["TBD"], related: ["Technofossil Archive"] },
