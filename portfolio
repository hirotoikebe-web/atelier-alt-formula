<script>
(function () {
  const targetPatterns = [
    'GOOD DESIGN NEW HOPE AWARD Archive',
    'GOOD DESIGN NEW HOPE AWARD',
    'Good Design New Hope Award'
  ];

  const sourcePatterns = [
    'PNEUMA',
    'Pneuma'
  ];

  // Fallback paths used only when a PNEUMA archive item cannot be found on the rendered page.
  const fallbackPneumaImages = [
    'assets/images/pneuma-01.jpg',
    'assets/images/pneuma-02.jpg',
    'assets/images/pneuma-03.jpg',
    'assets/images/pneuma-04.jpg',
    'assets/images/pneuma-05.jpg',
    'assets/images/pneuma-1.jpg',
    'assets/images/pneuma-2.jpg',
    'assets/images/pneuma-3.jpg',
    'assets/images/pneuma.jpg',
    'assets/images/PNEUMA.jpg',
    'assets/images/archive-pneuma-01.jpg',
    'assets/images/archive-pneuma-02.jpg',
    'assets/images/good-design-new-hope-pneuma.jpg',
    'assets/images/good-design-new-hope-award-01.jpg'
  ];

  const archiveRoot = document.getElementById('archive-list') || document.body;

  const normalize = (text) => {
    return (text || '').replace(/\s+/g, ' ').trim().toLowerCase();
  };

  const includesAny = (text, patterns) => {
    const normalized = normalize(text);
    return patterns.some((pattern) => normalized.includes(normalize(pattern)));
  };

  const getArchiveBlock = (element) => {
    return element.closest('article, section, li, .archive-card, .archive-item, .project-card, .card, [data-title], [data-archive]') || element;
  };

  const getUniqueBlocksByText = (patterns, excludePatterns = []) => {
    const selector = 'article, section, li, .archive-card, .archive-item, .project-card, .card, [data-title], [data-archive], h1, h2, h3, h4, a, p, div';
    const candidates = Array.from(archiveRoot.querySelectorAll(selector));
    const blocks = [];

    candidates.forEach((candidate) => {
      const text = candidate.textContent || '';
      if (!includesAny(text, patterns)) return;
      if (excludePatterns.length && includesAny(text, excludePatterns)) return;

      const block = getArchiveBlock(candidate);
      if (!block || !block.querySelector('img')) return;
      if (!blocks.includes(block)) blocks.push(block);
    });

    return blocks;
  };

  const clearResponsiveSources = (img) => {
    const picture = img.closest('picture');

    if (picture) {
      picture.querySelectorAll('source').forEach((source) => {
        source.removeAttribute('srcset');
        source.removeAttribute('sizes');
      });
    }

    img.removeAttribute('srcset');
    img.removeAttribute('sizes');
  };

  const setImageSource = (img, src, altText) => {
    if (!img || !src) return;

    clearResponsiveSources(img);

    img.src = src;
    img.alt = altText;
    img.dataset.pneumaImageApplied = 'true';

    const link = img.closest('a');
    if (link && /\.(jpg|jpeg|png|webp|gif|avif)$/i.test(link.getAttribute('href') || '')) {
      link.setAttribute('href', src);
    }
  };

  const collectPneumaSourcesFromPage = () => {
    const sourceBlocks = getUniqueBlocksByText(sourcePatterns, targetPatterns);
    const sources = [];

    sourceBlocks.forEach((block) => {
      block.querySelectorAll('img').forEach((img) => {
        const src = img.getAttribute('src') || img.currentSrc || img.src;
        if (src && !sources.includes(src)) sources.push(src);
      });
    });

    return sources;
  };

  const preloadFallbackSources = (callback) => {
    fallbackPneumaImages.forEach((path) => {
      const testImage = new Image();

      testImage.onload = () => {
        callback(path);
      };

      testImage.src = path;
    });
  };

  const applyPneumaImagesToGoodDesign = (sources) => {
    const targetBlocks = getUniqueBlocksByText(targetPatterns);
    if (!targetBlocks.length || !sources.length) return false;

    targetBlocks.forEach((block) => {
      const targetImages = Array.from(block.querySelectorAll('img'));

      targetImages.forEach((img, index) => {
        const source = sources[index % sources.length];
        setImageSource(img, source, 'PNEUMA');
      });
    });

    return true;
  };

  const run = () => {
    const sourcesFromPage = collectPneumaSourcesFromPage();

    if (sourcesFromPage.length) {
      applyPneumaImagesToGoodDesign(sourcesFromPage);
      return;
    }

    if (!archiveRoot.dataset.pneumaFallbackStarted) {
      archiveRoot.dataset.pneumaFallbackStarted = 'true';

      const fallbackSources = [];
      preloadFallbackSources((path) => {
        if (!fallbackSources.includes(path)) fallbackSources.push(path);
        applyPneumaImagesToGoodDesign(fallbackSources);
      });
    }
  };

  document.addEventListener('DOMContentLoaded', run);
  window.addEventListener('load', run);
  [100, 300, 800, 1500, 2500].forEach((delay) => window.setTimeout(run, delay));

  const observer = new MutationObserver(run);
  observer.observe(archiveRoot, { childList: true, subtree: true });
})();
</script>

